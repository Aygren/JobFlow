# Telegram API credentials (получаются на https://my.telegram.org)
API_ID=твой_числовой_id
API_HASH=твой_строковый_hash

# Supabase credentials (из настроек проекта в Supabase -> API)
SUPABASE_URL=https://твой-проект.supabase.co
SUPABASE_KEY=sb_secret_твои_ключи_анонимности_или_сервиса

# Если парсеру нужно взаимодействовать с n8n
N8N_WEBHOOK_URL=https://твой-инстанс-n8n.com/webhook/твой-путь

# Настройки для сессии (используем строку вместо файла для Render)
TELETHON_SESSION_STRING=