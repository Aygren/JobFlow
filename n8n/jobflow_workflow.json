    {
      "parameters": {
        "jsCode": "try {\n  const item = items[0];\n  const parsed = JSON.parse(item.json.output);\n  \n  return [{\n    json: {\n      id: item.json.id || 'unknown',\n      link: item.json.url || item.json.link || 'https://t.me/...', \n      \n      // Данные от AI\n      is_relevant: Boolean(parsed.is_relevant),\n      reason: parsed.reason || \"Причина не указана\",\n      \n      // Обновленные пути согласно новому промпту\n      cover_letter: parsed.response?.text || 'Отклик не сформирован',\n      contact: parsed.response?.contacts?.telegram || 'Контакты не найдены',\n      \n      has_error: true // Сохраняем твою логику: true при успехе\n    }\n  }];\n} catch (error) {\n  // При ошибке парсинга has_error: false\n  return [{ json: { has_error: false, error_details: error.message } }];\n}"
      },
