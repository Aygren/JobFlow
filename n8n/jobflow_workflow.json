    {
      "parameters": {
        "jsCode": "try {\n  const item = items[0];\n  const parsed = JSON.parse(item.json.output);\n  \n  // Определяем статус на основе категории от AI\n  let finalStatus = 'ignored';\n  if (parsed.category === 'sent') finalStatus = 'sent';\n  if (parsed.category === 'trash') finalStatus = 'trash';\n  if (parsed.category === 'ignored') finalStatus = 'ignored';\n\n  return [{\n    json: {\n      id: item.json.id || 'unknown',\n      link: item.json.url || item.json.link || 'https://t.me/...', \n      \n      // Направление для Switch-ноды\n      final_status: finalStatus,\n      \n      // Теперь здесь всегда будет подробный разбор вакансии от AI для базы данных\n      reason: parsed.reason || \"Причина не указана агентом\",\n      \n      // Сопроводительное письмо (будет заполнено только для sent)\n      cover_letter: parsed.response?.cover_letter || 'Отклик не сформирован',\n      contact: parsed.response?.contacts?.telegram || 'Контакты не найдены',\n      \n      has_error: true\n    }\n  }];\n} catch (error) {\n  return [{ json: { has_error: false, error_details: error.message, final_status: 'error' } }];\n}"
      },
