    {
      "parameters": {
        "jsCode": "// return items.slice(1);\n// Укажите здесь ID вакансии, которую нужно обработать\nconst TARGET_ID = 2; \n\n// Получаем все входящие данные\nconst items = $input.all();\n\n// Фильтруем массив: оставляем только тот элемент, у которого id совпадает с заданным\nconst filtered = items.filter(item => item.json.id === TARGET_ID);\n\nif (filtered.length === 0) {\n    throw new Error(`Вакансия с ID ${TARGET_ID} не найдена!`);\n}\n\nreturn filtered;"
      },
